{
    "Lua.runtime.version": "Lua 5.4",
    "Lua.workspace.library": [
        "C:/gitProjects/Lmaobox-Annotations/library"
    ],
    "Lua.workspace.checkThirdParty": true,
    "files.autoSave": "onFocusChange",
    "editor.formatOnSave": true,
    "[lua]": {
        "editor.defaultFormatter": "JohnnyMorganz.stylua",
        // Or if using LuaFormat: "editor.defaultFormatter": "koihik.vscode-lua-format",
        "editor.formatOnSave": true
    },
    "stylua.searchParentDirectories": true,
    "emeraldwalk.runonsave": {
        "commands": [
            {
                "match": "\\.lua$",
                "isAsync": true,
                "cmd": "\"${workspaceFolder}\\BundleAndDeploy.bat\"",
                "message": "Deploying ${fileBasename} to LocalAppData...",
                "autoShowOutputPanel": true
            }
        ]
    }
}